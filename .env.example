# ══════════════════════════════════════════════════════════════════════
# GOALQUEST - Variables de entorno centralizadas
# ══════════════════════════════════════════════════════════════════════

# ── Identity DB ──────────────────────────────────────────────────────
IDENTITY_DB_NAME=goalquest_identity
IDENTITY_DB_USER=postgres
IDENTITY_DB_PASSWORD=postgres_secret

# ── Tasks DB ─────────────────────────────────────────────────────────
TASKS_DB_NAME=tasks_db
TASKS_DB_USER=tasks_user
TASKS_DB_PASSWORD=tasks123

# ── Challenge MongoDB ────────────────────────────────────────────────
CHALLENGE_MONGO_ROOT_USER=admin
CHALLENGE_MONGO_ROOT_PASSWORD=admin123
CHALLENGE_MONGO_DB=challenge_db
CHALLENGE_MONGO_USER=challenge_user
CHALLENGE_MONGO_PASSWORD=challenge_pass

# ── Gamification MongoDB ─────────────────────────────────────────────
GAMIFICATION_MONGO_DB=gamification_db

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=goalquest-super-secret-key-change-in-production-min-32chars!!
JWT_EXPIRATION=86400

# ── Comunicación interna entre microservicios ────────────────────────
INTERNAL_SERVICE_KEY=goalquest-internal-secret-key-change-in-production

# ── Usuario admin predeterminado ─────────────────────────────────────
ADMIN_EMAIL=admin@goalquest.com
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Admin GoalQuest

# ── XP Rewards ───────────────────────────────────────────────────────
XP_REWARD_WINNER=100
XP_REWARD_LOSER=25
XP_REWARD_DRAW=50