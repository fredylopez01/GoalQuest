# App
PORT=3002
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://challenge_user:challenge_pass@localhost:27018/challenge_db

# Eureka
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_SERVICE_NAME=challenge-service
EUREKA_INSTANCE_HOST=localhost
EUREKA_INSTANCE_PORT=3002

# Internal Service Key (compartida entre microservicios)
INTERNAL_SERVICE_KEY=goalquest-internal-secret-key-change-in-production

# Services URLs (fallback si Eureka no disponible)
IDENTITY_SERVICE_URL=http://localhost:8081
GAMIFICATION_SERVICE_URL=http://localhost:8000

# XP Rewards for challenges
XP_REWARD_WINNER=100
XP_REWARD_LOSER=25
XP_REWARD_DRAW=50