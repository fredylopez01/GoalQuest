# ── Identity DB ─────────────────────────────────────────────────────────────────
IDENTITY_DB_NAME=goalquest_identity
IDENTITY_DB_USER=postgres
IDENTITY_DB_PASSWORD=postgres_secret

# ── JWT ──────────────────────────────────────────────────────────────────────────
# Cambiar en producción — debe ser al menos 256 bits (32 caracteres)
JWT_SECRET=goalquest-super-secret-key-change-in-production-min-32chars!!
JWT_EXPIRATION=86400

# ── Comunicación interna entre microservicios ────────────────────────────────────
INTERNAL_SERVICE_KEY=goalquest-internal-secret-key-change-in-production

# ── Usuario admin predeterminado ─────────────────────────────────────────────────
# Se crea automáticamente al primer arranque si no existe
ADMIN_EMAIL=admin@goalquest.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Admin GoalQuest
